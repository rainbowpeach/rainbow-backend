APP_ENV=prod
HOST=127.0.0.1
PORT=28081

DB_DRIVER=mysql
DB_DSN=root:password@tcp(127.0.0.1:3306)/rainbow_prod?charset=utf8mb4&parseTime=True&loc=Local
LOG_ROOT=/opt/rainbow-backend/logs/prod

JWT_SECRET=prod_jwt_secret_change_this
JWT_EXPIRES_IN=7200

ADMIN_USERNAME=admin
ADMIN_PASSWORD=prod_admin_password_change_this

ALLOW_ORIGINS=https://your-frontend.example.com

UPLOAD_ROOT=/opt/rainbow-backend/uploads/prod
UPLOAD_IMAGE_MAX_SIZE=52428800
UPLOAD_AUDIO_MAX_SIZE=52428800
