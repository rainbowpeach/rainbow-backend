APP_ENV=test
HOST=127.0.0.1
PORT=18081

DB_DRIVER=mysql
DB_DSN=root:password@tcp(127.0.0.1:3306)/rainbow_test?charset=utf8mb4&parseTime=True&loc=Local
LOG_ROOT=/opt/rainbow-backend/logs/test

JWT_SECRET=test_jwt_secret_change_this
JWT_EXPIRES_IN=7200

ADMIN_USERNAME=admin
ADMIN_PASSWORD=test_admin_password_change_this

ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

UPLOAD_ROOT=/opt/rainbow-backend/uploads/test
UPLOAD_IMAGE_MAX_SIZE=52428800
UPLOAD_AUDIO_MAX_SIZE=52428800
